"# ============================================
# SENSITIVE FILES - NEVER COMMIT THESE
# ============================================

# Environment Variables
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
**/.env
**/.env.local
**/.env.development
**/.env.test
**/.env.production

