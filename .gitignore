# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================
# LOGS & TEMPORARY FILES
# ============================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
lt.log

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
.tmp/
temp/

# ============================================
# TESTING & COVERAGE
# ============================================

# Test coverage
coverage/
*.lcov
.nyc_output/

# ============================================
# MISC
# ============================================

# Optional npm cache directory
.npm

